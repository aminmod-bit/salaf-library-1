{
  "name": "salaf-library",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run books:sync && npm run seo:generate && tsc --noEmit && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit && npm audit --audit-level=moderate",
    "import:books": "node scripts/import-content.mjs books",
    "import:audio": "node scripts/import-content.mjs audio",
    "import:biographies": "node scripts/import-content.mjs biographies",
    "import:fawaid": "node scripts/import-content.mjs fawaid",
    "import:all": "node scripts/import-content.mjs all",
    "import:github-books": "node scripts/import-github-books.mjs",
    "download:github-books": "node scripts/download-github-books.mjs",
    "import:github-books:download": "node scripts/import-github-books.mjs https://github.com/aminmod-bit/salaf-library/tree/main/books --mode=download",
    "polish:data": "node scripts/polish-library-data.mjs",
    "seo:generate": "node scripts/generate-seo.mjs",
    "metadata:enrich": "node scripts/enrich-book-metadata.mjs",
    "books:sync": "node scripts/sync-books-folders.mjs",
    "content:scan": "node scripts/content.mjs scan",
    "content:import": "node scripts/content.mjs import",
    "content:validate": "node scripts/content.mjs validate",
    "content:backup": "node scripts/content.mjs backup",
    "content:restore": "node scripts/content.mjs restore"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.21.0",
    "pdfjs-dist": "^5.4.394",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "3.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "^7.3.5"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
