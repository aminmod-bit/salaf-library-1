    { "name": "Азкары", "short_name": "Азкары", "description": "Открыть азкары и дуа", "url": "./#/azkar", "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }] },
    { "name": "Продолжить чтение", "short_name": "Читать", "description": "Открыть библиотеку", "url": "./#/history", "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }] }
