  "screenshots": [
    { "src": "./pwa-screenshot-wide.png", "sizes": "1280x720", "type": "image/png", "form_factor": "wide", "label": "Salaf Library desktop" },
    { "src": "./pwa-screenshot-mobile.png", "sizes": "540x960", "type": "image/png", "form_factor": "narrow", "label": "Salaf Library mobile" }
